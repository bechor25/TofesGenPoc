OPENAI_API_KEY=sk-...
# Extraction (two-stage grounded) vision model. Strong Hebrew: gpt-5.1 (default in code).
OPENAI_VISION_MODEL=gpt-5.1
# Image-edit model. gpt-image-2 gave the best Hebrew fidelity in visual comparison
# (best when the replacement count is SMALL — smart selective replacement keeps it small).
# gpt-image-1.5/1 support input_fidelity=high but garbled Hebrew in practice here.
OPENAI_IMAGE_MODEL=gpt-image-2
# Extraction backend: "openai" (default) or "ollama" (local Qwen3-VL; needs >32GB RAM).
EXTRACT_BACKEND=openai
OLLAMA_HOST=http://localhost:11434
OLLAMA_VL_MODEL=qwen3-vl:8b
# Archive DB (sources + generated images). Unset = persistence off.
#   local (no server): sqlite:///./tofes_archive.db
#   docker-compose:     postgresql+psycopg://tofes:tofes@db:5432/tofes
DATABASE_URL=sqlite:///./tofes_archive.db
