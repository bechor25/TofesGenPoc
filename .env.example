OPENAI_API_KEY=sk-...
# Extraction (two-stage grounded) vision model. Strong Hebrew: gpt-5.1 (default in code).
OPENAI_VISION_MODEL=gpt-5.1
# Image-edit model. gpt-image-1.5 / gpt-image-1 support input_fidelity=high (preserve the
# original, change only the values) -> better Hebrew fidelity. gpt-image-2 does NOT support
# it and regenerates the whole page. Code default if unset: gpt-image-2.
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Extraction backend: "openai" (default) or "ollama" (local Qwen3-VL; needs >32GB RAM).
EXTRACT_BACKEND=openai
OLLAMA_HOST=http://localhost:11434
OLLAMA_VL_MODEL=qwen3-vl:8b
